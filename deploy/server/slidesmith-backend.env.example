SLIDESMITH_HTTP_ADDR=0.0.0.0:18080
SLIDESMITH_GIN_MODE=release
SLIDESMITH_DB_DRIVER=sqlite
SLIDESMITH_DB_DSN=/root/slidesmith/backend/data/slidesmith.db
SLIDESMITH_STORAGE_ROOT=/root/slidesmith/backend/storage

SLIDESMITH_AGENT_COMPOSE_ENABLED=true
SLIDESMITH_AGENT_COMPOSE_CLI=/root/slidesmith/deploy/server/agent-compose-docker-cli.sh
SLIDESMITH_AGENT_COMPOSE_HOST=http://127.0.0.1:7410
SLIDESMITH_AGENT_COMPOSE_FILE=/data/work/agent-compose.yml
SLIDESMITH_AGENT_COMPOSE_WORKDIR=/root/slidesmith/runtime/ppt-master-agent
SLIDESMITH_AGENT_COMPOSE_WORKSPACE_ROOT=/root/slidesmith/runtime/ppt-master-agent/task-workspaces
SLIDESMITH_AGENT_COMPOSE_AGENT=ppt_master
SLIDESMITH_AGENT_COMPOSE_RUNTIME_IMAGE=slidesmith/ppt-master-runtime:dev
SLIDESMITH_PPT_MASTER_SKILL_DIR=/root/ppt-master/skills/ppt-master
SLIDESMITH_PPT_RUNNER_PROFILE=real-lite
# Set to full-ppt-master to use agent-compose prompt mode for the generate phase.
# Requires the agent-compose daemon to have a working Codex/LLM provider config.
SLIDESMITH_AGENT_COMPOSE_SESSION_ROOT=/root/slidesmith-agent-compose-data
SLIDESMITH_AGENT_COMPOSE_TIMEOUT=30m

SLIDESMITH_WORKER_POLL_INTERVAL=2s
SLIDESMITH_WORKER_BATCH_SIZE=1
