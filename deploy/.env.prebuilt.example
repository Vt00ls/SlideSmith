# Network-limited validation profile.
# Copy to deploy/.env.prebuilt when the server cannot pull Docker Hub build
# images. This profile reuses ghcr.io/chaitin/agent-compose:latest as the
# runtime base and expects prebuilt backend binaries plus frontend/dist.

COMPOSE_PROJECT_NAME=slidesmith-prebuilt

SLIDESMITH_PREBUILT_FRONTEND_PORT=18081
SLIDESMITH_PREBUILT_API_PORT=18082
SLIDESMITH_PREBUILT_AGENT_COMPOSE_PORT=127.0.0.1:17410

SLIDESMITH_PREBUILT_APP_DATA_ROOT=/root/slidesmith-compose-prebuilt/data/app
SLIDESMITH_PREBUILT_AGENT_COMPOSE_DATA_ROOT=/root/slidesmith-compose-prebuilt/data/agent-compose
SLIDESMITH_PREBUILT_AGENT_COMPOSE_HOST_SESSION_ROOT=/root/slidesmith-compose-prebuilt/data/agent-compose/sessions

SLIDESMITH_PPT_MASTER_SKILL_DIR_HOST=/root/slidesmith-deps/ppt-master/skills/ppt-master
SLIDESMITH_AGENT_COMPOSE_RUNTIME_IMAGE=slidesmith/ppt-master-runtime:dev
SLIDESMITH_AGENT_COMPOSE_ENV_FILE=./agent-compose.env.prebuilt
SLIDESMITH_AGENT_COMPOSE_TIMEOUT=30m

SLIDESMITH_PPT_RUNNER_PROFILE=real-lite
SLIDESMITH_FULL_PPT_DEFAULT_ENABLED=false
SLIDESMITH_FULL_PPT_PREFLIGHT_STRICT=true
SLIDESMITH_QUALITY_GATE_ENABLED=false
SLIDESMITH_QUALITY_GATE_STRICT=true
SLIDESMITH_PPTX_VALIDATE_ENABLED=false
SLIDESMITH_VISUAL_REVIEW_ENABLED=false
SLIDESMITH_VISUAL_REVIEW_DEFAULT=false
SLIDESMITH_BEAUTIFY_ENABLED=false
SLIDESMITH_BEAUTIFY_FIDELITY_STRICT=true
SLIDESMITH_BEAUTIFY_SOURCE_SVG_REFERENCE_ENABLED=false
SLIDESMITH_RESOURCE_PHASE_ENABLED=true
SLIDESMITH_RESOURCE_NETWORK_ENABLED=false
SLIDESMITH_RESOURCE_WEB_IMAGE_ENABLED=false
SLIDESMITH_RESOURCE_AI_IMAGE_ENABLED=false
SLIDESMITH_RESOURCE_FORMULA_NETWORK_ENABLED=false
SLIDESMITH_RESOURCE_AI_PATHS=api
SLIDESMITH_RESOURCE_ALLOWED_WEB_PROVIDERS=openverse,wikimedia
SLIDESMITH_RESOURCE_ALLOWED_AI_PROVIDERS=
SLIDESMITH_RESOURCE_MAX_FILES=100
SLIDESMITH_RESOURCE_MAX_TOTAL_BYTES=524288000
SLIDESMITH_RESOURCE_MAX_SINGLE_BYTES=52428800
SLIDESMITH_RESOURCE_TIMEOUT=20m
SLIDESMITH_WORKER_POLL_INTERVAL=2s
SLIDESMITH_WORKER_BATCH_SIZE=1

SLIDESMITH_PREBUILT_RUNTIME_BASE=ghcr.io/chaitin/agent-compose:latest
AGENT_COMPOSE_IMAGE=ghcr.io/chaitin/agent-compose:latest
