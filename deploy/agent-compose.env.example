# Copy to deploy/agent-compose.env before running Docker Compose.
# These variables are loaded by the agent-compose daemon container.

AUTH_USERNAME=admin
AUTH_PASSWORD=change-this-agent-compose-password
AUTH_SECRET=change-this-to-a-long-random-secret
AUTH_SESSION_TTL=24h

HTTP_LISTEN=0.0.0.0:7410
DATA_ROOT=/data
RUNTIME_DRIVER=docker
DEFAULT_IMAGE=ghcr.io/chaitin/agent-compose-guest:latest
DOCKER_DEFAULT_IMAGE=debian:bookworm-slim
AGENT_COMPOSE_RUNTIME_BASE_URL=http://agent-compose:7410
WORKSPACE_UPLOAD_LIMIT_BYTES=1073741824
TZ=Asia/Shanghai

# Required for full-ppt-master prompt mode.
# Keep these empty for real-lite smoke validation.
# LLM_API_ENDPOINT=https://api.openai.com
# LLM_API_PROTOCOL=responses
# LLM_API_KEY=
# OPENAI_API_KEY=
# LLM_MODEL=
# LLM_TIMEOUT=5m

SLIDESMITH_LIVE_PREVIEW_EDIT_ENABLED=false
SLIDESMITH_LIVE_PREVIEW_ANNOTATION_ENABLED=false
SLIDESMITH_LIVE_PREVIEW_MAX_ACTIVE_SESSIONS_PER_TASK=1
SLIDESMITH_LIVE_PREVIEW_SESSION_TTL_HOURS=168
