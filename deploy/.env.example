# Copy to deploy/.env before running Docker Compose.
#
# On the current test server, a practical install root is:
#   /root/slidesmith-compose
# If you run from another directory, keep these paths absolute so the
# agent-compose Docker driver can mount runtime sessions correctly.

COMPOSE_PROJECT_NAME=slidesmith

SLIDESMITH_FRONTEND_PORT=80

SLIDESMITH_APP_DATA_ROOT=/root/slidesmith-compose/data/app
SLIDESMITH_AGENT_COMPOSE_DATA_ROOT=/root/slidesmith-compose/data/agent-compose
SLIDESMITH_AGENT_COMPOSE_HOST_SESSION_ROOT=/root/slidesmith-compose/data/agent-compose/sessions
SLIDESMITH_POSTGRES_DATA_ROOT=/root/slidesmith-compose/data/postgres
SLIDESMITH_REDIS_DATA_ROOT=/root/slidesmith-compose/data/redis

SLIDESMITH_RUNTIME_SEED_HOST=/root/slidesmith/runtime/ppt-master-agent
SLIDESMITH_PPT_MASTER_SKILL_DIR_HOST=/root/slidesmith-deps/ppt-master/skills/ppt-master

SLIDESMITH_AGENT_COMPOSE_CONTAINER=slidesmith-agent-compose
SLIDESMITH_AGENT_COMPOSE_PORT=127.0.0.1:7410
SLIDESMITH_AGENT_COMPOSE_RUNTIME_IMAGE=slidesmith/ppt-master-runtime:dev
SLIDESMITH_AGENT_COMPOSE_ENV_FILE=./agent-compose.env
SLIDESMITH_AGENT_COMPOSE_TIMEOUT=30m

# Use real-lite for smoke validation. Switch to full-ppt-master after the
# agent-compose daemon has working LLM facade/provider configuration.
SLIDESMITH_PPT_RUNNER_PROFILE=real-lite

POSTGRES_DB=slidesmith
POSTGRES_USER=slidesmith
POSTGRES_PASSWORD=change-this-dev-password

AGENT_COMPOSE_IMAGE=ghcr.io/chaitin/agent-compose:latest
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine

# Build base images. Override these when Docker Hub is slow or unavailable.
SLIDESMITH_GO_IMAGE=golang:1.25-alpine
SLIDESMITH_DOCKER_CLI_IMAGE=docker:27-cli
SLIDESMITH_NODE_IMAGE=node:22-alpine
SLIDESMITH_NGINX_IMAGE=nginx:1.27-alpine

# Build dependency mirrors. Keep defaults for normal networks; override on
# restricted test servers, for example:
#   SLIDESMITH_GOPROXY=https://goproxy.cn,direct
#   SLIDESMITH_NPM_CONFIG_REGISTRY=https://registry.npmmirror.com/
SLIDESMITH_GOPROXY=https://proxy.golang.org,direct
SLIDESMITH_GOSUMDB=sum.golang.org
SLIDESMITH_NPM_CONFIG_REGISTRY=https://registry.npmjs.org/
